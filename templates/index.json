        "html": "<meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Carousel Vidéos Compact</title>\n\n  <style>\n    body {\n      margin: 0;\n      font-family: sans-serif;\n      background-color: #f5f5f5;\n    }\n\n    .title {\n      font-weight: bold;\n      font-size: 1.5rem;\n      text-align: center;\n      margin: 20px 0 10px 0;\n    }\n\n    .carousel-container {\n      overflow-x: auto;\n      padding: 20px 10px;\n      display: flex;\n      gap: 10px;\n      scroll-snap-type: x mandatory;\n      -webkit-overflow-scrolling: touch;\n    }\n\n    .video-card {\n      flex: 0 0 auto;\n      width: 140px;\n      border-radius: 15px;\n      box-shadow: 0 2px 6px rgba(0,0,0,0.2);\n      scroll-snap-align: start;\n      background-color: #000;\n      overflow: hidden;\n    }\n\n    .video-card video {\n      width: 100%;\n      height: auto;\n      display: block;\n      border-radius: 15px;\n      object-fit: cover;\n    }\n\n    /* cacher scrollbar */\n    .carousel-container::-webkit-scrollbar {\n      display: none;\n    }\n  </style>\n\n\n\n  <div class=\"title\">Już tysiące przemienionych uśmiechów</div>\n\n  <div class=\"carousel-container\">\n\n    <div class=\"video-card\">\n      <video autoplay=\"\" loop=\"\" muted=\"\" playsinline=\"\" webkit-playsinline=\"\" preload=\"auto\">\n        <source src=\"https://cdn.shopify.com/videos/c/o/v/b7f404b870024fa4a6091825f830ba85.mov\" type=\"video/mp4\">\n      </source></video>\n    </div>\n\n    <div class=\"video-card\">\n      <video autoplay=\"\" loop=\"\" muted=\"\" playsinline=\"\" webkit-playsinline=\"\" preload=\"auto\">\n        <source src=\"https://cdn.shopify.com/videos/c/o/v/4e0aae59d2c74e78bb8ad261c0dec905.mov\" type=\"video/mp4\">\n      </source></video>\n    </div>\n\n    <div class=\"video-card\">\n      <video autoplay=\"\" loop=\"\" muted=\"\" playsinline=\"\" webkit-playsinline=\"\" preload=\"auto\">\n        <source src=\"https://cdn.shopify.com/videos/c/o/v/a3fda2c3e877495a8f002e93fb3addbf.mov\" type=\"video/mp4\">\n      </source></video>\n    </div>\n\n    <div class=\"video-card\">\n      <video autoplay=\"\" loop=\"\" muted=\"\" playsinline=\"\" webkit-playsinline=\"\" preload=\"auto\">\n        <source src=\"https://cdn.shopify.com/videos/c/o/v/5e0f47c3750e48a598c75f78930631f2.mov\" type=\"video/mp4\">\n      </source></video>\n    </div>\n\n  </div>\n\n  <!-- Script autoplay mobile -->\n  <script>\n    document.querySelectorAll('video').forEach(video => {\n      const playPromise = video.play();\n\n      if (playPromise !== undefined) {\n        playPromise.catch(() => {\n          document.addEventListener('touchstart', () => {\n            video.play();\n          }, { once: true });\n        });\n      }\n    });\n  </script>",
